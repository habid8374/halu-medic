# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://halu_user:halu_pass@localhost:5432/halu_medic

# ─── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Factus API ────────────────────────────────────────────────────────────
# IMPORTANTE (SaaS): en producción cada consultorio configura SUS PROPIAS
# credenciales Factus desde Configuración → Facturación electrónica.
# Estas variables son SOLO un fallback para desarrollo single-tenant.
# Obtener en: https://developers.factus.com.co
FACTUS_BASE_URL=https://api-sandbox.factus.com.co
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=

# ─── Almacenamiento S3 / Wasabi ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=halu-medic-docs
AWS_S3_ENDPOINT_URL=https://s3.wasabisys.com

# ─── Email ─────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@halumedic.co

# ─── Tenant público ────────────────────────────────────────────────────────
PUBLIC_SCHEMA_DOMAIN=localhost

# ─── Frontend (para enlaces de recuperación de contraseña) ─────────────────
FRONTEND_URL=http://localhost:3000

# ─── Webhook Factus (opcional — firma HMAC para verificar autenticidad) ─────
# Configurar en panel Factus: Settings → Webhooks → Secret
FACTUS_WEBHOOK_SECRET=

# ─── RIPS / Prestador (se sobreescribe por tenant desde Consultorio) ────────
NIT_PRESTADOR=
CODIGO_PRESTADOR_RIPS=
